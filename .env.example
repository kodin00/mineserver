# Required: use a unique password of at least 12 characters.
ADMIN_PASSWORD=replace-with-a-long-random-password

# Panel HTTP port. Put an HTTPS reverse proxy in front for remote access.
PANEL_PORT=8080
COOKIE_SECURE=false

# This host path is mounted into the API at the same absolute path so sibling
# Minecraft containers can resolve generated bind mounts through the host daemon.
MINESERVER_DATA_ROOT=/opt/mineserver

TZ=Asia/Jakarta
SESSION_TTL_HOURS=24
MAX_UPLOAD_BYTES=2147483648
MAX_ZIP_EXPANDED_BYTES=4294967296
MAX_ZIP_FILES=500
